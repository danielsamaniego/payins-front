# Dev image for the Payins checkout (Next.js) with hot reload.
# Build context = the front repo root (Kunfupay-Payins-Front/). The repo-root
# `docker-compose.dev.yml` sets `context: .` and `dockerfile: apps/checkout/Dockerfile.dev`.

FROM node:22-alpine
RUN corepack enable && corepack prepare pnpm@10.13.1 --activate
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /workspace

# Workspace manifest + per-package manifests so pnpm can resolve the graph.
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc tsconfig.base.json ./
COPY packages/api-client/package.json ./packages/api-client/
COPY packages/types/package.json      ./packages/types/
COPY packages/money/package.json      ./packages/money/
COPY apps/checkout/package.json       ./apps/checkout/
COPY apps/dashboard/package.json      ./apps/dashboard/
RUN pnpm install --frozen-lockfile --filter '@payins/checkout...'

# Initial source copy; `docker-compose.dev.yml` bind-mounts src/messages/public on top
# for hot reload.
COPY packages      ./packages
COPY apps/checkout ./apps/checkout

WORKDIR /workspace/apps/checkout
EXPOSE 1466
CMD ["pnpm", "dev"]
