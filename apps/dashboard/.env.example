# Browser-visible base URL of the Payins Hono backend.
NEXT_PUBLIC_PAYINS_API_URL=http://localhost:1464

# Server-side (BFF) base URL used by Next route handlers / server components.
PAYINS_API_INTERNAL_URL=http://localhost:1464

# Secret used to sign the admin session cookie (BFF). Generate a strong random value.
SESSION_SECRET=change-me-in-production
